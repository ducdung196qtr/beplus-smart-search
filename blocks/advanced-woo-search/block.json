{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beplus-fast-product-filter-live-search-for-woocommerce/advanced-woo-search",
	"version": "1.0.0",
	"title": "Advanced Woo Search",
	"category": "woocommerce",
	"icon": "filter",
	"description": "Let shoppers search and filter your catalog on the spot—category, price, stock, and more, without reloading the page.",
	"keywords": [ "search", "woocommerce", "filter", "products", "advanced", "woo" ],
	"example": {
		"attributes": {
			"placeholder": "Search products…",
			"showKeyword": true,
			"showCategory": true
		}
	},
	"textdomain": "beplus-fast-product-filter-live-search-for-woocommerce",
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"attributes": {
		"placeholder": {
			"type": "string",
			"default": "Search products…"
		},
		"showKeyword": {
			"type": "boolean",
			"default": true
		},
		"showCategory": {
			"type": "boolean",
			"default": true
		},
		"showTag": {
			"type": "boolean",
			"default": true
		},
		"showAttributes": {
			"type": "boolean",
			"default": true
		},
		"showStock": {
			"type": "boolean",
			"default": true
		},
		"showOnSale": {
			"type": "boolean",
			"default": false
		},
		"showRating": {
			"type": "boolean",
			"default": false
		},
		"showFeatured": {
			"type": "boolean",
			"default": false
		},
		"showBrand": {
			"type": "boolean",
			"default": true
		},
		"showCustomTaxonomies": {
			"type": "boolean",
			"default": false
		},
		"attributeSlugs": {
			"type": "array",
			"default": []
		},
		"layout": {
			"type": "string",
			"enum": [ "inline", "sidebar" ],
			"default": "sidebar"
		},
		"resultsMode": {
			"type": "string",
			"enum": [ "filter-collection", "own-grid" ],
			"default": "filter-collection"
		},
		"resultsSelector": {
			"type": "string",
			"default": ".wp-block-woocommerce-product-collection"
		},
		"debounceMs": {
			"type": "number",
			"default": 280
		},
		"minChars": {
			"type": "number",
			"default": 2
		},
		"perPage": {
			"type": "number",
			"default": 10
		},
		"enableLiveSearch": {
			"type": "boolean",
			"default": true
		},
		"showResultCount": {
			"type": "boolean",
			"default": true
		},
		"showClearButton": {
			"type": "boolean",
			"default": true
		},
		"showPrice": {
			"type": "boolean",
			"default": true
		},
		"filterOrder": {
			"type": "array",
			"default": []
		},
		"enableResponsive": {
			"type": "boolean",
			"default": false
		},
		"showActiveFilters": {
			"type": "boolean",
			"default": true
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"style": "file:./style.css",
	"viewScript": [ "bpss-data", "file:./view.bundle.js" ]
}
