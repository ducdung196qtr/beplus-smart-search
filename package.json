{
	"name": "beplus-smart-search",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "npm run build:admin && npm run build:blocks",
		"build:admin": "node ./scripts/build-admin.mjs",
		"build:blocks": "node ./scripts/build-blocks.mjs",
		"watch": "concurrently --group -n Admin,Blocks -c yellow,magenta \"npm run -s watch:admin\" \"npm run -s watch:blocks\"",
		"watch:admin": "node ./scripts/build-admin.mjs --watch",
		"watch:blocks": "node ./scripts/build-blocks.mjs --watch",
		"build:package": "node ./scripts/build-package.mjs",
		"typecheck": "tsc --noEmit",
		"lint:php": "node ./scripts/composer.mjs phpstan",
		"lint:php:all": "node ./scripts/composer.mjs phpstan && node ./scripts/composer.mjs php-cs-fixer:check",
		"lint:php:fix": "node ./scripts/composer.mjs php-cs-fixer",
		"lint:php:check": "node ./scripts/composer.mjs php-cs-fixer:check",
		"composer": "node ./scripts/composer.mjs",
		"composer:install": "node ./scripts/composer.mjs install",
		"composer:update": "node ./scripts/composer.mjs update",
		"find-php": "powershell -NoProfile -File ./scripts/find-php.ps1",
		"git": "powershell -NoProfile -File ./scripts/git.ps1",
		"setup:git-path": "powershell -NoProfile -File ./scripts/setup-git-path.ps1",
		"gen": "node ./scripts/gen-block.mjs",
		"prepare": "husky",
		"precommit": "lint-staged && npm run lint:php:all",
		"ci": "npm run typecheck && npm run lint:php:all && npm run build"
	},
	"devDependencies": {
		"@types/wordpress__block-editor": "^15.0.5",
		"@types/wordpress__blocks": "^15.10.2",
		"@wordpress/block-editor": "^15.16.0",
		"@wordpress/blocks": "^15.16.0",
		"@wordpress/components": "^32.5.0",
		"@wordpress/element": "^6.43.0",
		"@wordpress/i18n": "^6.16.0",
		"@wordpress/server-side-render": "^6.19.0",
		"concurrently": "^9.2.1",
		"esbuild": "^0.25.0",
		"glob": "^13.0.6",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"typescript": "^5.8.2"
	}
}
