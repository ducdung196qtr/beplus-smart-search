{
	"name": "beplus/beplus-smart-search",
	"description": "BePlus Smart Search for WordPress",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"friendsofphp/php-cs-fixer": "^3.89",
		"phpstan/phpstan": "^2.1",
		"szepeviktor/phpstan-wordpress": "^2.0"
	},
	"autoload": {
		"psr-4": {
			"BePlusSmartSearch\\": "src/"
		}
	},
	"scripts": {
		"phpstan": "@php vendor/bin/phpstan analyse --memory-limit=1G",
		"php-cs-fixer": "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --verbose --show-progress=dots --allow-unsupported-php-version=yes",
		"php-cs-fixer:check": "@php vendor/bin/php-cs-fixer fix --config=.php-cs-fixer.dist.php --dry-run --diff --allow-unsupported-php-version=yes"
	}
}
