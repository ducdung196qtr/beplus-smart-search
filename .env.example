# Copy to `.env` and set the full path to php.exe if `composer` is not on PATH.
# Local WP: use "Open site shell" in Local, or find php.exe under:
#   %LOCALAPPDATA%\Programs\Local\lightning-services\php-*\bin\win64\php.exe
#
# Example (Windows):
# PHP_BIN=C:\Users\you\AppData\Local\Programs\Local\lightning-services\php-8.2.27+1\bin\win64\php.exe
